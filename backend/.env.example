# Copy this file to .env and edit as needed.
# .env is gitignored.

# SQLAlchemy database URL
# Development (default): local SQLite file
DATABASE_URL=sqlite:///./tarkov.db
# Production example (PostgreSQL):
# DATABASE_URL=postgresql://user:password@localhost/dbname

# Comma-separated list of allowed CORS origins (no spaces around commas).
# Development default: local file server on port 5500
CORS_ORIGINS=http://127.0.0.1:5500
# Production: set to your actual domain(s). When the frontend is served from the
# same origin as the API (e.g. via nginx proxy), CORS is not needed for the frontend
# itself, but you may still want to list the domain for safety.
# CORS_ORIGINS=https://example.com,https://www.example.com
